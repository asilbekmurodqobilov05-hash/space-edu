SECRET_KEY=your-secret-key-here-change-in-production

# Development: uses SQLite (no DB config needed)
# Production: uncomment and fill in PostgreSQL settings
# DB_NAME=spaceedu
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Production only
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
